# ══════════════════════════════════════════════════════════════
# Automated Agentic AI Web Agency — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── Agency Branding (Whitelabel) ──────────────────────────────
AGENCY_NAME="Web Agency"              # Your agency's display name
AGENCY_CALLER_NAME="Alex"             # AI caller persona name for phone calls
AGENCY_OWNER_NAME="The Owner"         # Owner/CEO name shown in messages
AGENCY_EMAIL=""                        # Primary contact email (e.g. hello@yourdomain.com)
AGENCY_PHONE=""                        # Default outbound phone number (e.g. +44...)
AGENCY_SLUG="web-agency"              # URL-safe agency identifier

# Dashboard Branding (Vite — prefix with VITE_)
VITE_AGENCY_NAME="Web Agency"
VITE_AGENCY_OWNER_NAME="The Owner"
VITE_AGENCY_EMAIL=""
VITE_AGENCY_DOMAIN=""                  # Your agency's domain (e.g. youragency.com)

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=""                        # Your Supabase project URL
SUPABASE_SERVICE_KEY=""                # Service role key (NOT anon key)

# ── Vercel ────────────────────────────────────────────────────
VERCEL_TOKEN=""                        # Vercel API token for deployments
VERCEL_TEAM_ID=""                      # (Optional) Vercel team/org ID

# ── Bland.ai (Phone Calls) ───────────────────────────────────
BLAND_AI_API_KEY=""                    # Bland.ai API key for outbound calls

# ── Stripe (Payments) ────────────────────────────────────────
STRIPE_SECRET_KEY=""                   # Stripe secret key
STRIPE_PRICE_SETUP=""                  # Price ID for website setup fee
STRIPE_PRICE_DOMAIN=""                 # Price ID for domain registration
STRIPE_WEBHOOK_SECRET=""               # Webhook signing secret
STRIPE_SUCCESS_URL=""                  # URL after successful payment
STRIPE_CANCEL_URL=""                   # URL if payment cancelled

# ── Telegram (Notifications + HITL) ──────────────────────────
TELEGRAM_BOT_TOKEN=""                  # Bot token from @BotFather
TELEGRAM_ADMIN_ID=""                   # Your Telegram user ID for notifications

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=""                      # Resend API key
OUTREACH_FROM_NAME=""                  # Sender display name
OUTREACH_FROM_EMAIL=""                 # Verified sender email

# ── Twilio (Client SMS/WhatsApp) ─────────────────────────────
TWILIO_ACCOUNT_SID=""                  # Twilio account SID
TWILIO_AUTH_TOKEN=""                   # Twilio auth token
TWILIO_SMS_FROM=""                     # Twilio SMS sender number (e.g. +44...)
TWILIO_WHATSAPP_FROM=""                # Twilio WhatsApp number (tries WhatsApp first, falls back to SMS)

# ── Google Places API ────────────────────────────────────────
GOOGLE_PLACES_API_KEY=""               # Google Places API key for lead discovery

# ── Gemini (Image Generation) ────────────────────────────────
GEMINI_API_KEY=""                      # Google Gemini API key

# ── HMRC (Business Verification) ─────────────────────────────
HMRC_VAT_CHECK="true"                 # Enable HMRC VAT registration check in verifier (true/false)

# ── Calendly ─────────────────────────────────────────────────
CALENDLY_LINK=""                       # Your Calendly booking link

# ── Server ───────────────────────────────────────────────────
PORT=3001                              # API server port
API_URL="http://localhost:3001"        # Public API URL (for tracking pixels etc.)
